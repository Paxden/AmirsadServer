{
  "name": "amirsad-gold-platform",
  "version": "1.0.0",
  "description": "Gold Trading Management Platform for AMIRSAD ENERGY CONSULT",
  "main": "server.js",
  "author": "AMIRSAD ENERGY CONSULT",
  "license": "ISC",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "seed": "node scripts/seeder.js",
    "seed:delete": "node scripts/seeder.js --delete",
    "db:backup": "node scripts/backup.js",
    "security": "npm audit",
    "precommit": "npm run lint && npm run test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mailtrap": "^4.6.0",
    "mongoose": "^9.7.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "pdfkit": "^0.19.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/fixtures/"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "jest": true,
      "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2021
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "server.js"
    ],
    "ext": "js,json",
    "ignore": [
      "src/uploads/*",
      "src/tests/*"
    ],
    "exec": "node server.js",
    "env": {
      "NODE_ENV": "development"
    }
  }
}
